RewriteEngine On

# 🚦 1. Redirect Legacy Tools to LAB Subdomain
RewriteRule ^(calculators|ai-tools|financial-tools|date-tools|converters|health-tools|visa-tools|about-us|contact|faq|privacy-policy|terms-of-service)\.html$ https://lab.upanita.com/$1.html [R=301,L]

# 🚦 2. Redirect Legacy Runner Pages to RUNNER Subdomain
RewriteRule ^(runner-launchpad|runner-board)\.html$ https://runner.upanita.com/index.html [R=301,L]

# 🚦 3. Redirect Tool Assets to LAB
RewriteRule ^assets/(css|js|images)/(.*)$ https://lab.upanita.com/assets/$1/$2 [R=301,L]

# 🚦 4. Handle Udyog Marg (SPA Routing)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]
